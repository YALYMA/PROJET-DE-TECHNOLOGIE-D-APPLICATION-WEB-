# UNCHK API — Variables d'environnement
# Copier ce fichier en .env et adapter les valeurs

# Serveur
PORT=3000
NODE_ENV=development

# Frontend (CORS)
FRONTEND_URL=http://localhost:4200

# Backend Spring Boot — l'API proxyfie toutes les requêtes vers cette URL
BACKEND_URL=http://localhost:8080

# JWT — DOIT être identique à uck.jwt.secret dans application.properties
JWT_SECRET=unchk-secret-key-tres-longue-et-securisee-2026-changez-en-prod

# Logs
LOG_LEVEL=info
